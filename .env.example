# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/linkup_schema_matcher?schema=public"

# AI Provider (ollama | lmstudio | nvidia)
AI_PROVIDER="ollama"

# AI request settings
AI_REQUEST_TIMEOUT_MS=60000
AI_SUGGEST_MAX_TOKENS=700

# Ollama
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1"

# LM Studio
LM_STUDIO_BASE_URL="http://localhost:1234/v1"
LM_STUDIO_MODEL="local-model"

# NVIDIA
NVIDIA_API_KEY=""
NVIDIA_MODEL="meta/llama-3.1-8b-instruct"
