generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SchemaTemplate {
  id              String            @id @default(cuid())
  name            String
  description     String?
  jsonSchema      Json
  canonicalFields Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  runs            MappingRun[]
  templates       MappingTemplate[]
}

model UploadedFile {
  id           String       @id @default(cuid())
  originalName String
  storagePath  String
  workbookMeta Json?
  createdAt    DateTime     @default(now())
  runs         MappingRun[]
}

model MappingRun {
  id               String           @id @default(cuid())
  uploadedFileId   String?
  schemaTemplateId String
  sourceSheetName  String?
  sourceMode       String           @default("headered")
  columnProfiles   Json?
  sampleRows       Json?
  maskingAudit     Json?
  maskedRowPatterns Json?
  headerResolution Json?
  suggestedMapping Json?
  confirmedMapping Json?
  draftToken       String?          @unique
  displayName      String?
  status           String           @default("draft")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  output           GeneratedOutput?
  schemaTemplate   SchemaTemplate   @relation(fields: [schemaTemplateId], references: [id])
  uploadedFile     UploadedFile?    @relation(fields: [uploadedFileId], references: [id])
}

model MappingTemplate {
  id               String         @id @default(cuid())
  schemaTemplateId String
  name             String
  sourceSignature  String?
  confirmedMapping Json
  isFavorite       Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  schemaTemplate   SchemaTemplate @relation(fields: [schemaTemplateId], references: [id])
}

model GeneratedOutput {
  id           String     @id @default(cuid())
  mappingRunId String     @unique
  jsonOutput   Json
  errors       Json?
  createdAt    DateTime   @default(now())
  mappingRun   MappingRun @relation(fields: [mappingRunId], references: [id])
}
